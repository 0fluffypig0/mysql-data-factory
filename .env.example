# ========================================
# 数据库连接配置
# ========================================
DB_HOST=jump-jp.ebaocloud.com
DB_PORT=33061
DB_USER=your_user_id
DB_PASSWORD=your_password
DB_NAME=cloverit_bo_db
DB_CHARSET=utf8mb4

# ========================================
# 目标表配置
# ========================================
TARGET_TABLE=t_legal

# ========================================
# 批量插入配置
# ========================================
TOTAL_ROWS=10000
BATCH_SIZE=1000

# ========================================
# 数据生成配置
# ========================================
FAKER_LOCALE=ja_JP

# ========================================
# 数据目录配置
# ========================================
DATA_DIR=data
DATA_TEMPLATE_DIR=data/templates
DATA_OUTPUT_DIR=data/output