# ==============================================
# MySQL Data Factory 2.0 - Configuration
# ==============================================

# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database
DB_CHARSET=utf8mb4

# Legacy V1.x settings (still supported by CLI scripts)
TARGET_TABLE=your_table
TABLE_PROFILE_PATH=config/table_profiles.json
PRIMARY_KEY_COLUMNS=id
UNIQUE_KEY_COLUMNS=
JSON_COLUMNS=

# Default parameters
EXPORT_SAMPLE_LIMIT=3
DEFAULT_CHUNK_SIZE=5000
INSERT_BATCH_SIZE=500
CSV_BASE_DIR=data
