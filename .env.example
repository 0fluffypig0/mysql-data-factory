# Database connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database
DB_CHARSET=utf8mb4

# Minimal single-table workflow
TARGET_TABLE=your_table
PRIMARY_KEY_COLUMNS=id

# Optional workflow defaults
UNIQUE_KEY_COLUMNS=
TIME_OFFSET_COLUMNS=
JSON_COLUMNS=
TIME_OFFSET_DAYS=0
TIME_OFFSET_SECONDS=0
EXPORT_SAMPLE_LIMIT=3
INSERT_BATCH_SIZE=500
CSV_BASE_DIR=data
