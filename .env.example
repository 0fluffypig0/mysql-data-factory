# =============================================================
# MySQL Data Factory 3.0.2 - Connection Configuration
# Copy this file to `.env` and fill in your database credentials.
# =============================================================

# --- Required: database connection ---
# [JP] データベース接続情報（必須）
# [CN] 数据库连接信息（必填）
#
# DB_DIALECT picks the backend. Supported values:
#   mysql       → MySQL 5.7 / 8.0 / 8.4, MariaDB 10.x / 11.x, Aurora MySQL, Percona
#   postgresql  → PostgreSQL 12–16, Aurora PostgreSQL, Cloud SQL PG, TimescaleDB
#   oracle      → Oracle 12c / 19c / 21c / 23ai, Autonomous DB, Exadata (thin mode)
#   sqlite      → single-file / :memory:  (only DB_NAME is read, as a file path)
#
# For mysql / postgresql / oracle: set DB_HOST, DB_PORT, DB_USER, DB_PASSWORD,
# DB_NAME (+ DB_CHARSET for mysql only). For oracle, DB_NAME is the Oracle
# service_name (SID also accepted via Easy Connect).
# For sqlite: only DB_NAME is read — relative paths resolve from the project
# root; use the literal ":memory:" for an in-memory DB.
DB_DIALECT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password
DB_NAME=your_database
DB_CHARSET=utf8mb4

# --- Example: PostgreSQL instead of MySQL ---
# [JP] PostgreSQL を使う場合は上の MySQL ブロックを無効化し、以下を有効化
# [CN] 如需改用 PostgreSQL，注释上面的 MySQL 块并启用下面几行
#DB_DIALECT=postgresql
#DB_HOST=127.0.0.1
#DB_PORT=5432
#DB_USER=your_user
#DB_PASSWORD=your_password
#DB_NAME=your_database

# --- Example: Oracle instead of MySQL ---
# DB_NAME holds the Oracle service_name (e.g. ORCLPDB1, XEPDB1). python-oracledb
# runs in "thin" mode, so no Oracle Instant Client install is required.
# [JP] Oracle の場合。DB_NAME は service_name を入れる（Instant Client 不要）
# [CN] Oracle 时 DB_NAME 填 service_name（无需 Instant Client）
#DB_DIALECT=oracle
#DB_HOST=127.0.0.1
#DB_PORT=1521
#DB_USER=your_user
#DB_PASSWORD=your_password
#DB_NAME=ORCLPDB1

# --- Example: SQLite instead of MySQL ---
# To target SQLite, comment out the MySQL block above and uncomment below.
# [JP] SQLite を使う場合は上の MySQL ブロックを無効化し、以下を有効化
# [CN] 如需改用 SQLite，注释上面的 MySQL 块并启用下面的两行
#DB_DIALECT=sqlite
#DB_NAME=data/mydata.sqlite3

# --- Optional: CLI script defaults ---
# Only used by scripts/ CLIs (smoke_test.py, wizard.py, pressure_test_100k.py, ...).
# The GUI reads its own settings from the Connection / Tasks tabs.
# [JP] CLI スクリプト用のデフォルト値（任意）
# [CN] CLI 脚本默认参数（可选）
EXPORT_SAMPLE_LIMIT=3
DEFAULT_CHUNK_SIZE=5000
INSERT_BATCH_SIZE=500
CSV_BASE_DIR=data

# --- Legacy: V1.x single-table mode (kept for backward-compat) ---
# New users can ignore these. They are only read by a few older
# single-table scripts. Uncomment and fill in only if needed.
# [JP] 旧 V1.x 互換用（新規利用では不要）
# [CN] V1.x 兼容字段（新项目可忽略）
#TARGET_TABLE=your_table
#TABLE_PROFILE_PATH=config/table_profiles.json
#PRIMARY_KEY_COLUMNS=id
#UNIQUE_KEY_COLUMNS=
#JSON_COLUMNS=
